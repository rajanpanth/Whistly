# ============================================================
# InstinctFi — Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# Supabase — get these from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Site URL (for OG images, canonical URLs, sharing)
NEXT_PUBLIC_SITE_URL=https://instinctfi.com

# Auth secret for JWT signing (generate: openssl rand -base64 32)
AUTH_JWT_SECRET=your-jwt-secret-here
# S-10: Previous JWT secret for rotation (set when rotating AUTH_JWT_SECRET)
# AUTH_JWT_SECRET_PREV=your-old-jwt-secret-here

# Supabase Service Role Key — found in Supabase Dashboard > Settings > API
# Required for server-side RPC calls. NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Upstash Redis — for production rate limiting (S-07)
# Free tier: 10K commands/day. Get credentials at https://console.upstash.com
# If not set, falls back to in-memory rate limiting (fine for dev).
# UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# Push notifications (optional — VAPID keys)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_PRIVATE_KEY=your-vapid-private-key

# Solana network (devnet | mainnet-beta)
NEXT_PUBLIC_SOLANA_NETWORK=devnet
# Optional: custom RPC endpoint (defaults to clusterApiUrl)
# NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# Admin wallets — comma-separated base58 pubkeys (UI gating only;
# authoritative check is the admin_wallets Supabase table)
NEXT_PUBLIC_ADMIN_WALLETS=YOUR_ADMIN_WALLET_PUBKEY

# Optional: social / footer links
# NEXT_PUBLIC_TWITTER_URL=https://x.com/instinctfi
# NEXT_PUBLIC_DISCORD_URL=https://discord.gg/instinctfi
# NEXT_PUBLIC_GITHUB_URL=https://github.com/instinctfi
